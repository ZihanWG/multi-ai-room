OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

OPENAI_MODEL=gpt-5.5
# claude-opus-4-8 is the most capable default; claude-sonnet-4-6 is a cheaper, faster alternative.
CLAUDE_MODEL=claude-opus-4-8
GEMINI_MODEL=gemini-3.1-pro

# Per-provider request timeout in seconds.
REQUEST_TIMEOUT_SECONDS=60

# Provider retry count after the initial request. Set to 0 to disable retries.
PROVIDER_MAX_RETRIES=2

# Max generated tokens per model call.
MAX_OUTPUT_TOKENS=1200

# Max characters copied from each prior agent output into later prompts.
MAX_PROMPT_CONTEXT_CHARS=1800

# Review-stage provider: auto, openai, anthropic, or gemini.
# auto tries configured providers in OpenAI -> Anthropic -> Gemini order.
CRITIC_PROVIDER=auto
MODERATOR_PROVIDER=auto

# Set to true to run deterministic local demo responses without calling model APIs.
DEMO_MODE=false
